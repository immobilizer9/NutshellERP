# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@localhost:5432/nutshell_erp"

# ── Authentication ─────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET="change-this-to-a-long-random-secret"

# ── Email (Nodemailer / SMTP) ──────────────────────────────────────────────────
# Set these to enable order approval emails, task notifications, design emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Nutshell ERP <your-email@gmail.com>"

# ── Google Drive (content backup + import — OAuth2) ───────────────────────────
# Create at: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Set Authorised redirect URI to: {NEXT_PUBLIC_APP_URL}/api/drive/callback
GOOGLE_CLIENT_ID="your-google-oauth2-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth2-client-secret"
# Optional: default folder ID (overridden by Admin → Settings folder picker)
GOOGLE_DRIVE_FOLDER_ID="your-google-drive-folder-id"

# ── Google Sheets export ────────────────────────────────────────────────────────
GOOGLE_SHEETS_ID="your-google-sheets-spreadsheet-id"

# ── App URL ────────────────────────────────────────────────────────────────────
# Used for email links and PDF generation (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Cron Jobs ──────────────────────────────────────────────────────────────────
# Secret token for protecting /api/cron/* endpoints
# Generate with: openssl rand -hex 32
CRON_SECRET="change-this-to-a-random-secret"

# ── Database Seeding ───────────────────────────────────────────────────────────
# The seed script is blocked in production unless this is set to "true"
# ALLOW_SEED="true"
