# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@localhost:5432/nutshell_erp"

# ── Authentication ─────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET="change-this-to-a-long-random-secret"

# ── Email (Nodemailer / SMTP) ──────────────────────────────────────────────────
# Set these to enable order approval emails, task notifications, design emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Nutshell ERP <your-email@gmail.com>"

# ── Google Drive (content backup + import) ─────────────────────────────────────
# Service account for Google Drive access (reuses Google Sheets credentials)
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-sa@your-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# ID of the shared Drive folder (share it with GOOGLE_SERVICE_ACCOUNT_EMAIL)
GOOGLE_DRIVE_FOLDER_ID="your-google-drive-folder-id"

# ── Google Sheets export ────────────────────────────────────────────────────────
GOOGLE_SHEETS_ID="your-google-sheets-spreadsheet-id"

# ── App URL ────────────────────────────────────────────────────────────────────
# Used for email links and PDF generation (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Cron Jobs ──────────────────────────────────────────────────────────────────
# Secret token for protecting /api/cron/* endpoints
# Generate with: openssl rand -hex 32
CRON_SECRET="change-this-to-a-random-secret"

# ── Database Seeding ───────────────────────────────────────────────────────────
# The seed script is blocked in production unless this is set to "true"
# ALLOW_SEED="true"
