# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@localhost:5432/nutshell_erp"

# ── Authentication ─────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET="change-this-to-a-long-random-secret"

# ── Email (Nodemailer / SMTP) ──────────────────────────────────────────────────
# Set these to enable order approval emails, task notifications, design emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Nutshell ERP <your-email@gmail.com>"

# ── App URL ────────────────────────────────────────────────────────────────────
# Used for email links and PDF generation (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Cron Jobs ──────────────────────────────────────────────────────────────────
# Secret token for protecting /api/cron/* endpoints
# Generate with: openssl rand -hex 32
CRON_SECRET="change-this-to-a-random-secret"

# ── Database Seeding ───────────────────────────────────────────────────────────
# The seed script is blocked in production unless this is set to "true"
# ALLOW_SEED="true"
