    "jsonwebtoken": "^9.0.3",
    "next": "16.1.6",
    "nodemailer": "^8.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.10.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
