{
  "name": "erp-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "tsc --noEmit && prisma generate",
    "reset": "prisma db push --force-reset && prisma generate && node prisma/seed.js",
    "verify": "npm run check && npm run build",
    "next-feature": "node automation/nextFeature.js",
    "create-feature": "node automation/createFeature.js",
    "health": "node automation/systemHealth.js",
    "safe": "node automation/gitSafe.js",
    "schema-check": "node automation/schemaIntelligence.js",
    "evolve": "node automation/evolve.js"
  },
