generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  password       String
  phone          String?  // ✅ Sales rep phone number
  isActive       Boolean  @default(true)
  organizationId String
  managerId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization  @relation(fields: [organizationId], references: [id])
  roles           UserRole[]
  manager         User?         @relation("UserHierarchy", fields: [managerId], references: [id])
  team            User[]        @relation("UserHierarchy")
  ordersCreated   Order[]       @relation("OrderCreator")
  visits          Visit[]
  dailyReports    DailyReport[]
  assignedTasks   Task[]        @relation("UserAssignedTasks")
  createdTasks    Task[]        @relation("UserCreatedTasks")
  assignedSchools   School[]          @relation("SchoolAssignment")
  createdEvents     SchoolEvent[]     @relation("EventCreator")
  targets           Target[]
  competitorNotes   CompetitorNote[]  @relation("CompetitorNoteCreator")
  notifications     Notification[]

  contentTopicsAssigned   ContentTopic[]           @relation("TopicAssignee")
  contentTopicsCreated    ContentTopic[]           @relation("TopicCreator")
  contentDocuments        ContentDocument[]        @relation("DocAuthor")
  questionBanks           QuestionBank[]           @relation("QBCreator")
  trainingMaterials       TrainingMaterial[]       @relation("MatCreator")
  quizSessionsConducted   QuizSession[]            @relation("QuizConductor")
  quizTrainerSessions     QuizSessionTrainer[]     @relation("QuizTrainer")
  trainingConducted       TrainingSession[]        @relation("TrainingConductor")
  trainingTrainerSessions TrainingSessionTrainer[] @relation("TrainingTrainer")
  schoolActivities        SchoolActivity[]         @relation("ActivityCreator")
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  roles RolePermission[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model AuditLog {
  id             String   @id @default(uuid())
  action         String
  entity         String?  // e.g. "Order", "School", "User"
  entityId       String?  // ID of the affected record
  userId         String?
  userName       String?  // denormalized for display without join
  organizationId String
  metadata       Json?
  createdAt      DateTime @default(now())
}

model School {
  id            String  @id @default(uuid())
  name          String
  address       String
  city          String
  state         String
  latitude      Float   @default(0)
  longitude     Float   @default(0)
  contactPerson String?
  contactPhone  String?

  assignedToId String?
  assignedTo   User?   @relation("SchoolAssignment", fields: [assignedToId], references: [id])

  pipelineStage PipelineStage @default(LEAD)

  visits          Visit[]
  orders          Order[]
  events          SchoolEvent[]
  competitorNotes CompetitorNote[]

  quizSessions          QuizSession[]
  participatingQuizzes  QuizParticipatingSchool[]
  trainingSessions      TrainingSession[]
  activities            SchoolActivity[]

  createdAt DateTime @default(now())
}

model Order {
  id String @id @default(uuid())

  schoolId    String
  school      School @relation(fields: [schoolId], references: [id])

  createdById String
  createdBy   User   @relation("OrderCreator", fields: [createdById], references: [id])

  type        String @default("ORIGINAL")
  // Values: ORIGINAL | ADDITIONAL

  productType String @default("ANNUAL")
  // Values: ANNUAL | PAPERBACKS_PLAINS | PAPERBACKS_HILLS | NUTSHELL_ANNUAL | NUTSHELL_PAPERBACKS

  status String @default("PENDING")
  // Values: PENDING | APPROVED | REJECTED

  grossAmount Float
  netAmount   Float

  // School contact details at time of order
  schoolEmail  String?
  schoolPhone  String?
  address1     String?
  address2     String?
  pincode      String?
  orderDate    DateTime?
  deliveryDate DateTime?

  // ✅ Vendor details
  vendorName    String?
  vendorPhone   String?
  vendorEmail   String?
  vendorAddress String?

  // Payment tracking
  paymentStatus String  @default("UNPAID")
  // Values: UNPAID | PARTIAL | PAID
  paidAmount    Float   @default(0)

  // Delivery tracking
  deliveryStatus String    @default("PENDING")
  // Values: PENDING | DISPATCHED | DELIVERED
  deliveredAt    DateTime?

  // Generated PDF download URL
  pdfUrl String?

  // Rejection reason (set when status → REJECTED)
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items   OrderItem[]
  returns Return[]
  pocs    OrderPOC[]
}

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  className String
  quantity  Int
  mrp       Float
  unitPrice Float
  total     Float

  returns Return[]
}

model OrderPOC {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  role  String
  name  String?
  phone String?
  email String?

  createdAt DateTime @default(now())
}

model Return {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  itemId String
  item   OrderItem @relation(fields: [itemId], references: [id])

  quantity Int
  amount   Float
  reason   String?

  createdAt DateTime @default(now())
}

model DailyReport {
  id        String  @id @default(uuid())
  summary   String
  location  String?
  latitude  Float?
  longitude Float?

  status    String  @default("PENDING")
  bdComment String?

  salesUserId String
  salesUser   User   @relation(fields: [salesUserId], references: [id])

  createdAt DateTime @default(now())
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  status      String   @default("PENDING")
  priority    String   @default("MEDIUM")
  // Values: LOW | MEDIUM | HIGH

  assignedToId String
  assignedById String

  assignedTo User @relation("UserAssignedTasks", fields: [assignedToId], references: [id])
  assignedBy User @relation("UserCreatedTasks", fields: [assignedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompetitorNote {
  id String @id @default(uuid())

  schoolId    String
  school      School @relation(fields: [schoolId], references: [id])

  createdById String
  createdBy   User   @relation("CompetitorNoteCreator", fields: [createdById], references: [id])

  competitor  String
  // Who the competitor is: e.g. "Oxford", "S.Chand", "NavNeet"
  notes       String?
  isActive    Boolean @default(true)
  // Is this competitor currently active at this school?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Target {
  id             String @id @default(uuid())
  userId         String
  user           User   @relation(fields: [userId], references: [id])
  organizationId String

  month          Int    // 1–12
  year           Int

  revenueTarget  Float  @default(0)
  ordersTarget   Int    @default(0)
  incentivePercent Float @default(0)   // % of achieved revenue paid as incentive

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month, year])
}

model Visit {
  id String @id @default(uuid())

  schoolId    String
  school      School @relation(fields: [schoolId], references: [id])

  salesUserId String
  salesUser   User   @relation(fields: [salesUserId], references: [id])

  outcome       String?
  // Values: INTERESTED | FOLLOW_UP | NOT_INTERESTED | ORDER_PLACED
  nextVisitDate DateTime?
  notes         String?
  createdAt     DateTime @default(now())
}

model SchoolEvent {
  id   String    @id @default(uuid())
  type EventType

  date  DateTime
  notes String?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdById String
  createdBy   User   @relation("EventCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

enum EventType {
  QUIZ
  TEACHER_TRAINING
  MEETING
}

enum PipelineStage {
  LEAD
  CONTACTED
  VISITED
  PROPOSAL_SENT
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

model Notification {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  organizationId String

  type       String
  // Values: ORDER_APPROVED | ORDER_REJECTED | TASK_ASSIGNED | OVERDUE_TASK

  title      String
  message    String
  entityType String?  // "Order" | "Task" | "School"
  entityId   String?

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ContentTopic {
  id          String   @id @default(uuid())
  title       String
  description String?
  productType String   // ANNUAL | PAPERBACKS_PLAINS | PAPERBACKS_HILLS | ONLINE
  classFrom   Int
  classTo     Int
  status      String   @default("OPEN")  // OPEN | IN_PROGRESS | COMPLETED
  dueDate     DateTime?

  assignedToId String
  assignedById String
  assignedTo   User   @relation("TopicAssignee", fields: [assignedToId], references: [id])
  assignedBy   User   @relation("TopicCreator",  fields: [assignedById],  references: [id])

  documents ContentDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentDocument {
  id      String @id @default(uuid())
  title   String

  topicId  String
  topic    ContentTopic @relation(fields: [topicId], references: [id])

  authorId String
  author   User   @relation("DocAuthor", fields: [authorId], references: [id])

  body    String  @default("")
  status  String  @default("DRAFT")
  // DRAFT | SUBMITTED | APPROVED | REJECTED | DESIGN_SENT | PUBLISHED

  version      Int     @default(1)
  adminComment String?

  designedFileUrl  String?
  designedFileName String?
  sentToDesignAt   DateTime?
  publishedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuestionBank {
  id          String  @id @default(uuid())
  title       String
  description String?
  subject     String  @default("GK")
  classFrom   Int
  classTo     Int
  difficulty  String  @default("MEDIUM")  // EASY | MEDIUM | HARD
  status      String  @default("DRAFT")   // DRAFT | PUBLISHED | ARCHIVED

  createdById    String
  createdBy      User       @relation("QBCreator", fields: [createdById], references: [id])
  organizationId String

  questions Question[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Question {
  id            String  @id @default(uuid())
  bankId        String
  bank          QuestionBank @relation(fields: [bankId], references: [id])
  text          String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String  // A | B | C | D
  explanation   String?
  classLevel    Int?
  difficulty    String  @default("MEDIUM")
  createdAt     DateTime @default(now())
}

model TrainingMaterial {
  id          String  @id @default(uuid())
  title       String
  description String?
  type        String  // PDF | SLIDES | VIDEO | DOCUMENT
  url         String?
  topic       String  // BOOK_USAGE | QUIZ_METHODOLOGY | BOTH

  createdById    String
  createdBy      User   @relation("MatCreator", fields: [createdById], references: [id])
  organizationId String

  trainingSessions TrainingSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuizSession {
  id          String   @id @default(uuid())
  title       String
  format      String   // IN_SCHOOL | INTER_SCHOOL
  status      String   @default("SCHEDULED")  // SCHEDULED | COMPLETED | CANCELLED
  scheduledDate  DateTime
  completedDate  DateTime?

  schoolId       String?
  school         School?  @relation(fields: [schoolId], references: [id])

  conductedById  String?
  conductedBy    User?    @relation("QuizConductor", fields: [conductedById], references: [id])

  organizationId     String
  participatingStudents Int?
  booksPitched       Boolean @default(false)
  booksPitchedNotes  String?
  overallNotes       String?

  trainers            QuizSessionTrainer[]
  classResults        QuizClassResult[]
  topPerformers       QuizTopPerformer[]
  participatingSchools QuizParticipatingSchool[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuizSessionTrainer {
  id           String      @id @default(uuid())
  quizSessionId String
  quizSession  QuizSession @relation(fields: [quizSessionId], references: [id])
  userId       String
  user         User        @relation("QuizTrainer", fields: [userId], references: [id])

  @@unique([quizSessionId, userId])
}

model QuizParticipatingSchool {
  id           String      @id @default(uuid())
  quizSessionId String
  quizSession  QuizSession @relation(fields: [quizSessionId], references: [id])
  schoolId     String
  school       School      @relation(fields: [schoolId], references: [id])
  rank         Int?
  score        Float?
}

model QuizClassResult {
  id           String      @id @default(uuid())
  quizSessionId String
  quizSession  QuizSession @relation(fields: [quizSessionId], references: [id])
  className        String
  studentsPresent  Int
  averageScore     Float?
  topScore         Float?
  teacherFeedback  String?
  createdAt        DateTime @default(now())
}

model QuizTopPerformer {
  id           String      @id @default(uuid())
  quizSessionId String
  quizSession  QuizSession @relation(fields: [quizSessionId], references: [id])
  studentName  String
  className    String
  score        Float?
  rank         Int?
  schoolId     String?
}

model TrainingSession {
  id    String @id @default(uuid())
  title String
  topic String  // BOOK_USAGE | QUIZ_METHODOLOGY | BOTH
  status String @default("SCHEDULED")  // SCHEDULED | COMPLETED | CANCELLED
  scheduledDate  DateTime
  completedDate  DateTime?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  conductedById String?
  conductedBy   User?   @relation("TrainingConductor", fields: [conductedById], references: [id])

  organizationId   String
  teachersAttended Int?
  durationMinutes  Int?
  overallNotes     String?
  teacherFeedback  String?
  followUpRequired Boolean @default(false)
  followUpNotes    String?

  trainers  TrainingSessionTrainer[]
  materials TrainingMaterial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainingSessionTrainer {
  id                String          @id @default(uuid())
  trainingSessionId String
  trainingSession   TrainingSession @relation(fields: [trainingSessionId], references: [id])
  userId            String
  user              User            @relation("TrainingTrainer", fields: [userId], references: [id])

  @@unique([trainingSessionId, userId])
}

model SchoolActivity {
  id            String   @id @default(uuid())
  type          String   // VISIT | QUIZ | TEACHER_TRAINING
  status        String   @default("SCHEDULED")  // SCHEDULED | COMPLETED | CANCELLED
  scheduledDate DateTime
  completedDate DateTime?
  notes         String?
  location      String?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  userId String
  user   User   @relation("ActivityCreator", fields: [userId], references: [id])

  organizationId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
