generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  password       String
  phone          String?  // ✅ Sales rep phone number
  isActive       Boolean  @default(true)
  organizationId String
  managerId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization  @relation(fields: [organizationId], references: [id])
  roles           UserRole[]
  manager         User?         @relation("UserHierarchy", fields: [managerId], references: [id])
  team            User[]        @relation("UserHierarchy")
  ordersCreated   Order[]       @relation("OrderCreator")
  visits          Visit[]
  dailyReports    DailyReport[]
  assignedTasks   Task[]        @relation("UserAssignedTasks")
  createdTasks    Task[]        @relation("UserCreatedTasks")
  assignedSchools   School[]          @relation("SchoolAssignment")
  createdEvents     SchoolEvent[]     @relation("EventCreator")
  targets           Target[]
  competitorNotes   CompetitorNote[]  @relation("CompetitorNoteCreator")
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  roles RolePermission[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model AuditLog {
  id             String   @id @default(uuid())
  action         String
  entity         String?  // e.g. "Order", "School", "User"
  entityId       String?  // ID of the affected record
  userId         String?
  userName       String?  // denormalized for display without join
  organizationId String
  metadata       Json?
  createdAt      DateTime @default(now())
}

model School {
  id            String  @id @default(uuid())
  name          String
  address       String
  city          String
  state         String
  latitude      Float   @default(0)
  longitude     Float   @default(0)
  contactPerson String?
  contactPhone  String?

  assignedToId String?
  assignedTo   User?   @relation("SchoolAssignment", fields: [assignedToId], references: [id])

  pipelineStage PipelineStage @default(LEAD)

  visits          Visit[]
  orders          Order[]
  events          SchoolEvent[]
  competitorNotes CompetitorNote[]

  createdAt DateTime @default(now())
}

model Order {
  id String @id @default(uuid())

  schoolId    String
  school      School @relation(fields: [schoolId], references: [id])

  createdById String
  createdBy   User   @relation("OrderCreator", fields: [createdById], references: [id])

  type        String @default("ORIGINAL")
  // Values: ORIGINAL | ADDITIONAL

  productType String @default("ANNUAL")
  // Values: ANNUAL | PAPERBACKS_PLAINS | PAPERBACKS_HILLS | NUTSHELL_ANNUAL | NUTSHELL_PAPERBACKS

  status String @default("PENDING")
  // Values: PENDING | APPROVED | REJECTED

  grossAmount Float
  netAmount   Float

  // School contact details at time of order
  schoolEmail  String?
  schoolPhone  String?
  address1     String?
  address2     String?
  pincode      String?
  orderDate    DateTime?
  deliveryDate DateTime?

  // ✅ Vendor details
  vendorName    String?
  vendorPhone   String?
  vendorEmail   String?
  vendorAddress String?

  // Payment tracking
  paymentStatus String  @default("UNPAID")
  // Values: UNPAID | PARTIAL | PAID
  paidAmount    Float   @default(0)

  // Delivery tracking
  deliveryStatus String    @default("PENDING")
  // Values: PENDING | DISPATCHED | DELIVERED
  deliveredAt    DateTime?

  // Generated PDF download URL
  pdfUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items   OrderItem[]
  returns Return[]
  pocs    OrderPOC[]
}

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  className String
  quantity  Int
  mrp       Float
  unitPrice Float
  total     Float

  returns Return[]
}

model OrderPOC {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  role  String
  name  String?
  phone String?
  email String?

  createdAt DateTime @default(now())
}

model Return {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  itemId String
  item   OrderItem @relation(fields: [itemId], references: [id])

  quantity Int
  amount   Float
  reason   String?

  createdAt DateTime @default(now())
}

model DailyReport {
  id        String  @id @default(uuid())
  summary   String
  location  String?
  latitude  Float?
  longitude Float?

  status    String  @default("PENDING")
  bdComment String?

  salesUserId String
  salesUser   User   @relation(fields: [salesUserId], references: [id])

  createdAt DateTime @default(now())
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  status      String   @default("PENDING")
  priority    String   @default("MEDIUM")
  // Values: LOW | MEDIUM | HIGH

  assignedToId String
  assignedById String

  assignedTo User @relation("UserAssignedTasks", fields: [assignedToId], references: [id])
  assignedBy User @relation("UserCreatedTasks", fields: [assignedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompetitorNote {
  id String @id @default(uuid())

  schoolId    String
  school      School @relation(fields: [schoolId], references: [id])

  createdById String
  createdBy   User   @relation("CompetitorNoteCreator", fields: [createdById], references: [id])

  competitor  String
  // Who the competitor is: e.g. "Oxford", "S.Chand", "NavNeet"
  notes       String?
  isActive    Boolean @default(true)
  // Is this competitor currently active at this school?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Target {
  id             String @id @default(uuid())
  userId         String
  user           User   @relation(fields: [userId], references: [id])
  organizationId String

  month          Int    // 1–12
  year           Int

  revenueTarget  Float  @default(0)
  ordersTarget   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month, year])
}

model Visit {
  id String @id @default(uuid())

  schoolId    String
  school      School @relation(fields: [schoolId], references: [id])

  salesUserId String
  salesUser   User   @relation(fields: [salesUserId], references: [id])

  outcome       String?
  // Values: INTERESTED | FOLLOW_UP | NOT_INTERESTED | ORDER_PLACED
  nextVisitDate DateTime?
  notes         String?
  createdAt     DateTime @default(now())
}

model SchoolEvent {
  id   String    @id @default(uuid())
  type EventType

  date  DateTime
  notes String?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdById String
  createdBy   User   @relation("EventCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
}

enum EventType {
  QUIZ
  TEACHER_TRAINING
  MEETING
}

enum PipelineStage {
  LEAD
  CONTACTED
  VISITED
  PROPOSAL_SENT
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}
